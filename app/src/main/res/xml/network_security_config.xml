<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!--
      LX custom sources frequently return short-lived http:// media URLs from arbitrary CDN
      hosts. Android cannot enumerate those hosts at build time, so playback must allow cleartext
      media traffic globally. Script HTTP requests remain separately restricted by the LX host.
    -->
    <base-config cleartextTrafficPermitted="true" />

    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">localhost</domain>
        <domain includeSubdomains="false">127.0.0.1</domain>
        <domain includeSubdomains="false">::1</domain>
        <!-- Android emulator host loopback -->
        <domain includeSubdomains="false">10.0.2.2</domain>
    </domain-config>

    <domain-config cleartextTrafficPermitted="true">
        <!-- NetEase playback URLs are commonly served as http://m*.music.126.net/... -->
        <domain includeSubdomains="true">music.126.net</domain>
    </domain-config>

    <domain-config cleartextTrafficPermitted="true">
        <!-- KuGou's public search endpoint is still served over plain HTTP. -->
        <domain includeSubdomains="true">mobilecdn.kugou.com</domain>
    </domain-config>
</network-security-config>
