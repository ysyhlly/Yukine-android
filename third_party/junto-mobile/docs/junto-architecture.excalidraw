      "locked": false
    },
    {
      "id": "txt_129",
      "type": "text",
      "x": 2274,
      "y": 2364,
      "width": 902,
      "height": 612,
      "angle": 0,
      "strokeColor": "#212529",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": "frame_120",
      "roundness": null,
      "seed": 1257,
      "version": 1,
      "versionNonce": 1258,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "newline-delimited JSON, both directions:\n  -> {\"command\": [\"set_property\",\"pause\",true], \"request_id\": 7}\n  <- {\"error\": \"success\", \"request_id\": 7}\n  <- {\"event\": \"property-change\", \"name\": \"pause\", \"data\": true}\n\n* Launch() starts mpv as a subprocess and connects to its socket,\n  retrying until the socket file actually appears on disk\n* every synced property is OBSERVED (observe_property), never polled\n* a coalescing event queue collapses repeated updates to the SAME\n  property down to just the latest value, instead of ever dropping one\n  under a burst (e.g. every property resetting when a new file loads)\n* an oversized IPC line is skipped and resynced at the next line,\n  instead of being mistaken for mpv crashing and killing the session\n* adding a new synced property means touching four spots: the obs*\n  const, the Engine field, the observation map, and the echo-\n  suppression struct — aid (audio track) is the worked example",
      "fontSize": 12.5,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": "rect_128",
      "originalText": "newline-delimited JSON, both directions:\n  -> {\"command\": [\"set_property\",\"pause\",true], \"request_id\": 7}\n  <- {\"error\": \"success\", \"request_id\": 7}\n  <- {\"event\": \"property-change\", \"name\": \"pause\", \"data\": true}\n\n* Launch() starts mpv as a subprocess and connects to its socket,\n  retrying until the socket file actually appears on disk\n* every synced property is OBSERVED (observe_property), never polled\n* a coalescing event queue collapses repeated updates to the SAME\n  property down to just the latest value, instead of ever dropping one\n  under a burst (e.g. every property resetting when a new file loads)\n* an oversized IPC line is skipped and resynced at the next line,\n  instead of being mistaken for mpv crashing and killing the session\n* adding a new synced property means touching four spots: the obs*\n  const, the Engine field, the observation map, and the echo-\n  suppression struct — aid (audio track) is the worked example",
      "lineHeight": 1.35,
      "baseline": 12.5
    },
