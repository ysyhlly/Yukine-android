    {
      "id": "txt_12",
      "type": "text",
      "x": 94,
      "y": 404,
      "width": 902,
      "height": 612,
      "angle": 0,
      "strokeColor": "#212529",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": "frame_3",
      "roundness": null,
      "seed": 1023,
      "version": 1,
      "versionNonce": 1024,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "WHAT'S ACTUALLY RUNNING:\n• two symmetric roles: host (`junto create`) and joiner (`junto join <code>`)\n• coordination (play/pause/seek/chat/kick) travels over PUBLIC Nostr relays,\n  every event NIP-44 encrypted end to end\n• the video itself NEVER touches a relay or any server — it goes host to\n  joiner over a direct WebRTC data channel, peer to peer\n• every session generates a fresh, throwaway keypair — nothing is tied to\n  a persistent identity, on either the relay side or the WebRTC side\n• two independent transport layers doing two very different jobs:\n  a slow/public one for tiny control messages, a fast/private one for\n  every byte of actual media",
      "fontSize": 12.5,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": "rect_11",
      "originalText": "WHAT'S ACTUALLY RUNNING:\n• two symmetric roles: host (`junto create`) and joiner (`junto join <code>`)\n• coordination (play/pause/seek/chat/kick) travels over PUBLIC Nostr relays,\n  every event NIP-44 encrypted end to end\n• the video itself NEVER touches a relay or any server — it goes host to\n  joiner over a direct WebRTC data channel, peer to peer\n• every session generates a fresh, throwaway keypair — nothing is tied to\n  a persistent identity, on either the relay side or the WebRTC side\n• two independent transport layers doing two very different jobs:\n  a slow/public one for tiny control messages, a fast/private one for\n  every byte of actual media",
      "lineHeight": 1.35,
      "baseline": 12.5
    },
