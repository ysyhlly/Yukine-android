      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "rect_34",
      "originalText": "Room ID\nsha256(secret,\"room\") — PUBLIC\nrelay filter tag",
      "lineHeight": 1.25,
      "baseline": 11
    },
    {
