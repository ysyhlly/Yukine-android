    {
      "id": "rect_62",
      "type": "rectangle",
      "x": 80,
      "y": 1370,
      "width": 930,
      "height": 640,
      "angle": 0,
      "strokeColor": "#495057",
      "backgroundColor": "#f8f9fa",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": "frame_52",
