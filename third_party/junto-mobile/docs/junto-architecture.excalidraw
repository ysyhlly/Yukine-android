    },
    {
      "id": "txt_37",
      "type": "text",
      "x": 2793.0,
      "y": 398,
      "width": 324,
      "height": 54,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
