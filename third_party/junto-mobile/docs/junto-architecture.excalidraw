      "originalText": "2. fails -> built-in TURN relay, automatically",
      "lineHeight": 1.25,
      "baseline": 12
    },
    {
      "id": "rect_71",
      "type": "rectangle",
      "x": 1170,
      "y": 1440,
      "width": 930,
      "height": 570,
      "angle": 0,
      "strokeColor": "#495057",
      "backgroundColor": "#f8f9fa",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": "frame_64",
      "roundness": {
        "type": 3
      },
      "seed": 1141,
      "version": 1,
      "versionNonce": 1142,
      "isDeleted": false,
      "boundElements": [
