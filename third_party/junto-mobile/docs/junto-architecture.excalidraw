          "type": "text",
          "id": "txt_72"
        }
      ],
      "updated": 1,
      "link": null,
      "locked": false
    },
    {
      "id": "txt_72",
      "type": "text",
      "x": 1184,
      "y": 1454,
      "width": 902,
      "height": 542,
      "angle": 0,
      "strokeColor": "#212529",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": "frame_64",
      "roundness": null,
      "seed": 1143,
      "version": 1,
      "versionNonce": 1144,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "TURN fallback details:\n* short-lived HMAC credentials for the built-in relay, fetched on demand\n  (never a permanent secret baked into the binary)\n* InitBuiltinRelay: 1s timeout at session START — don't block startup\n  waiting on a relay that may not even be needed\n* EnsureFallbackRelayFresh: 5s timeout, used only once NAT has already\n  been confirmed to fail — worth waiting longer at that point\n* credentials are cached and refetched once their TTL elapses — never\n  fetched once at startup and blindly trusted for the whole session\n* `-turn <url> -turn-user -turn-pass` lets you point at your own TURN\n  server instead of the built-in one\n\nResilience note: a transient WebRTC \"Disconnected\" state (a brief ICE\nflap, common on wifi) gets a short grace period to self-heal before\nbeing treated as a real failure — unlike \"Failed\"/\"Closed\", which are\nunambiguous and tear down immediately, no grace period given.",
      "fontSize": 12.5,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": "rect_71",
      "originalText": "TURN fallback details:\n* short-lived HMAC credentials for the built-in relay, fetched on demand\n  (never a permanent secret baked into the binary)\n* InitBuiltinRelay: 1s timeout at session START — don't block startup\n  waiting on a relay that may not even be needed\n* EnsureFallbackRelayFresh: 5s timeout, used only once NAT has already\n  been confirmed to fail — worth waiting longer at that point\n* credentials are cached and refetched once their TTL elapses — never\n  fetched once at startup and blindly trusted for the whole session\n* `-turn <url> -turn-user -turn-pass` lets you point at your own TURN\n  server instead of the built-in one\n\nResilience note: a transient WebRTC \"Disconnected\" state (a brief ICE\nflap, common on wifi) gets a short grace period to self-heal before\nbeing treated as a real failure — unlike \"Failed\"/\"Closed\", which are\nunambiguous and tear down immediately, no grace period given.",
      "lineHeight": 1.35,
      "baseline": 12.5
    },
