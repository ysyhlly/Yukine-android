    },
    {
      "id": "txt_82",
      "type": "text",
      "x": 2520,
      "y": 1315,
      "width": 410,
      "height": 20,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": "frame_73",
      "roundness": null,
      "seed": 1163,
