      "updated": 1,
      "link": null,
      "locked": false,
      "text": "Tiny, encrypted, ephemeral notes — the only thing public relays ever see.",
      "fontSize": 16,
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Tiny, encrypted, ephemeral notes — the only thing public relays ever see.",
