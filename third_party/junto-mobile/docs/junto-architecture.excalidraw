    {
      "id": "txt_119",
      "type": "text",
      "x": 1184,
      "y": 2364,
      "width": 902,
      "height": 612,
      "angle": 0,
      "strokeColor": "#212529",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": "frame_108",
      "roundness": null,
      "seed": 1237,
      "version": 1,
      "versionNonce": 1238,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "* every peer advertises a CanHost flag in its hello (true only if it\n  holds the actual local files, not just a streaming copy)\n* once the ORIGINAL host is confirmed gone, the eligible peer with the\n  LARGEST pubkey promotes itself — every peer computes the SAME winner\n  independently; no election messages, no coordination round-trip\n* the new host re-broadcasts the playlist so late joiners still find it\n* streaming joiners redirect their in-flight download to the new host\n  on the next retry (SetHost) — bytes stay SHA-256-verified across the\n  switch, so a redirect can never inject corrupt data\n* the promotion announcement repeats for a few heartbeats and is\n  honored even from a peer never exchanged hellos with before, as long\n  as the old host is already confirmed dead — otherwise one dropped\n  relay message could strand a joiner on a dead host forever\n* stale-room detection: one missed heartbeat cycle -> \"host appears to\n  have left\"; a longer gap escalates to a clear \"use /quit\" notice",
      "fontSize": 12.5,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": "rect_118",
      "originalText": "* every peer advertises a CanHost flag in its hello (true only if it\n  holds the actual local files, not just a streaming copy)\n* once the ORIGINAL host is confirmed gone, the eligible peer with the\n  LARGEST pubkey promotes itself — every peer computes the SAME winner\n  independently; no election messages, no coordination round-trip\n* the new host re-broadcasts the playlist so late joiners still find it\n* streaming joiners redirect their in-flight download to the new host\n  on the next retry (SetHost) — bytes stay SHA-256-verified across the\n  switch, so a redirect can never inject corrupt data\n* the promotion announcement repeats for a few heartbeats and is\n  honored even from a peer never exchanged hellos with before, as long\n  as the old host is already confirmed dead — otherwise one dropped\n  relay message could strand a joiner on a dead host forever\n* stale-room detection: one missed heartbeat cycle -> \"host appears to\n  have left\"; a longer gap escalates to a clear \"use /quit\" notice",
      "lineHeight": 1.35,
      "baseline": 12.5
    },
