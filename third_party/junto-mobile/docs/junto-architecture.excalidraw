      "link": null,
      "locked": false
    },
    {
      "id": "txt_63",
      "type": "text",
      "x": 94,
      "y": 1384,
      "width": 902,
      "height": 612,
      "angle": 0,
      "strokeColor": "#212529",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": "frame_52",
      "roundness": null,
      "seed": 1125,
      "version": 1,
      "versionNonce": 1126,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "non-trickle ICE: each side gathers ALL its own network candidates\nLOCALLY first, so only ONE SDP blob has to cross the relay each way —\nnot a stream of individual candidates, which would be slow over relay\nlatency and multiply the number of round trips needed.\n\n  1. host builds an SDP offer, waits for ICE gathering to finish,\n     sends it as one \"signal\" event\n  2. joiner applies it, builds an SDP answer, sends it back the same way\n  3. both sides open the WebRTC PeerConnection + one data channel\n  4. from this point on, ALL further traffic (video bytes, control\n     frames) flows directly between the two computers — relays are\n     completely out of the loop until the NEXT file or reconnect\n\nOnly one signal round-trip per file transfer is why transfers are a\nSINGLE persistent connection now, instead of the old design that\nrebuilt the connection (fresh ICE + SDP over relays) every 4 MiB —\nwhich throttled throughput below HD bitrates on any real link.",
      "fontSize": 12.5,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": "rect_62",
      "originalText": "non-trickle ICE: each side gathers ALL its own network candidates\nLOCALLY first, so only ONE SDP blob has to cross the relay each way —\nnot a stream of individual candidates, which would be slow over relay\nlatency and multiply the number of round trips needed.\n\n  1. host builds an SDP offer, waits for ICE gathering to finish,\n     sends it as one \"signal\" event\n  2. joiner applies it, builds an SDP answer, sends it back the same way\n  3. both sides open the WebRTC PeerConnection + one data channel\n  4. from this point on, ALL further traffic (video bytes, control\n     frames) flows directly between the two computers — relays are\n     completely out of the loop until the NEXT file or reconnect\n\nOnly one signal round-trip per file transfer is why transfers are a\nSINGLE persistent connection now, instead of the old design that\nrebuilt the connection (fresh ICE + SDP over relays) every 4 MiB —\nwhich throttled throughput below HD bitrates on any real link.",
      "lineHeight": 1.35,
      "baseline": 12.5
    },
    {
